# ================================================
# E-Commerce Frontend Environment Variables
# ================================================

# App Configuration
VITE_APP_NAME=BuyGlimmer
VITE_APP_DESCRIPTION=Your One-Stop Shop for Quality Products
VITE_APP_URL=http://localhost:5173

# ================================================
# API URLs (Local Development)
# ================================================

# Auth API - Routes through Vite proxy to SabbpeUAT-Auth-backend (port 8081)
VITE_AUTH_API_URL=http://localhost:8081

# Brand/Product API - Routes through Vite proxy to BuyGlimmer-Backend (port 8080)
VITE_BRAND_API_URL=http://localhost:8080

# ================================================
# Payment Configuration (Fill when integrating)
# ================================================

# Payment Environment (uat/prod)
VITE_PAYMENT_ENV=uat

# Payment Return URLs
VITE_PAYMENT_RETURN_URL=
VITE_PAYMENT_RETURN_BACKEND_URL=

# Payment Credentials
VITE_PAYMENT_TRANSACTION_USERID=
VITE_PAYMENT_TRANSACTION_MERCHANTID=
VITE_PAYMENT_CLIENT_ID=

# ================================================
# Optional Features (Leave empty if not needed)
# ================================================

# Email/Notification Service
VITE_MAIL_URL=http://localhost:8081

# Encryption Keys
VITE_ENCRYPTION_KEY=
VITE_ENCRYPTION_IV=

# ================================================
# Production URLs (Uncomment when going live)
# ================================================

# VITE_APP_URL=https://yourdomain.com
# VITE_AUTH_API_URL=https://your-auth-api.com
# VITE_BRAND_API_URL=https://your-api.com
# VITE_PAYMENT_ENV=prod
